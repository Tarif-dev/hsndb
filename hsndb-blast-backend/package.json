{
  "name": "hsndb-blast-backend",
  "version": "1.0.0",
  "description": "BLAST search backend for HSNDB",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "docker:build": "docker build -t hsndb-blast-backend .",
    "docker:run": "docker run -p 3001:10000 --env-file .env hsndb-blast-backend",
    "docker:dev": "docker run -p 3001:10000 -v %cd%:/app --env-file .env hsndb-blast-backend"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
