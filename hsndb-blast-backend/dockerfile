# Use official Node.js runtime with Ubuntu base (needed for BLAST+)
FROM node:18-bullseye

# Set working directory
WORKDIR /app

# Install system dependencies and BLAST+
RUN apt-get update && apt-get install -y \
    ncbi-blast+ \
    wget \
    curl \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Verify BLAST+ installation and check location
RUN blastp -version && which blastp && which makeblastdb && ls -la /usr/bin/blast*

# Ensure PATH includes BLAST+ binaries
ENV PATH="/usr/bin:$PATH"

# Copy package files first (for better caching)
COPY package*.json ./

# Install Node.js dependencies
RUN npm ci --only=production

# Copy application code
COPY . .

# Ensure sequences.fasta exists
RUN test -f sequences.fasta || { echo "sequences.fasta not found!"; exit 1; }

# Create necessary directories
RUN mkdir -p temp blastdb

# Build BLAST database from sequences.fasta
RUN makeblastdb -in sequences.fasta -dbtype prot -out blastdb/hsndb -title "HSNDB" && \
    ls -la blastdb/ && \
    echo "BLAST database created successfully"

# Set permissions
RUN chmod -R 755 /app

# Create non-root user for security
RUN useradd -m -u 1001 appuser && chown -R appuser:appuser /app

# Ensure appuser can access BLAST+ binaries
RUN chmod +x /usr/bin/blast* && \
    ls -la /usr/bin/blast* && \
    which blastp && \
    su appuser -c "which blastp" && \
    su appuser -c "blastp -version"

USER appuser

# Ensure PATH is set for appuser
ENV PATH="/usr/bin:$PATH"

# Expose port
EXPOSE 10000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:10000/api/health || exit 1

# Start the application
CMD ["npm", "start"]
